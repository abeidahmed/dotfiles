set nu
set relativenumber
set scrolloff=8
set incsearch
set clipboard=unnamedplus
set clipboard+=unnamed
set clipboard+=ideaput
set visualbell " No annoying sound on errors
set multiple-cursors
set ideajoin " Use Idea to join lines smartly
set idearefactormode=keep
set ideastatusicon=gray

Plug "tpope/vim-surround"

nnoremap <SPACE> <Nop>
let mapleader="\<Space>"

" Shortcutting split navigation
map <c-h> <C-w>h
map <c-j> <C-w>j
map <c-k> <C-w>k
map <c-l> <C-w>l

" Navigation
"nnoremap <c-j> :action ActivateTerminalToolWindow<CR>

nmap <leader>rn <Action>(RenameElement)
nmap ]d <Action>(GotoNextError)
nmap [d <Action>(GotoPreviousError)
nmap ]] <Action>(MethodDown)
nmap [[ <Action>(MethodUp)
nmap gl <Action>(ShowErrorDescription)

" LSP
nmap gO <Action>(FileStructurePopup)

" Find
nmap <leader>ff <Action>(GotoFile)
nmap <leader>sg <Action>(FindInPath)
nmap <leader>fu <Action>(FindUsages)
nmap <leader>s. <Action>(RecentFiles)

" Tests
nmap <leader>rt <Action>(ContextRun)
nmap <leader>rl <Action>(Rerun)
nmap <leader>rf <Action>(RunClass)

" Moving lines
vmap <a-k> <Action>(MoveLineUp)
vmap <a-j> <Action>(MoveLineDown)

" Behave vim
nnoremap Y y$

" Keep visual selection
vnoremap < <gv
vnoremap > >gv

" vim-rails keymaps
command! A action GotoTest

set NERDTree
set commentary

sethandler <c-v> a:ide

nmap <leader>n :NERDTree<CR>
